# Local dev: relative path works via the Vite dev server proxy (see vite.config.ts).
# Production (Vercel): this MUST be the full backend URL, since the frontend
# (Vercel) and backend (Railway) are on different domains and there is no
# proxy in production. Set this in the Vercel project's Environment Variables
# — Vite bakes VITE_* vars in at build time, so it must be set before the
# build runs, e.g.:
#   VITE_API_BASE_URL=https://<your-app>.up.railway.app/api/v1
VITE_API_BASE_URL=/api/v1
