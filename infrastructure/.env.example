# ============================================================
# App Environment — Docker Compose Template
# ============================================================
# This file is used by docker-compose.yml and docker-compose.prod.yml.
# Docker service names (db, minio, mailhog) are resolved by the internal network.

# Database
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=dev_password_only
DB_DATABASE=placement_tracker
DB_SSL=false

# JWT
JWT_SECRET=change-me-to-a-random-64-char-hex
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=placement-tracker

# Storage (MinIO / S3)
STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_BUCKET=placement-proofs
STORAGE_UPLOAD_URL_EXPIRY=3600
STORAGE_DOWNLOAD_URL_EXPIRY=300
STORAGE_USE_SSL=false

# Mail
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@placement.local
MAIL_TEMPLATE_DIR=./templates/email
MAIL_SECURE=
MAIL_REJECT_UNAUTHORIZED=true

# App
APP_PORT=3000
APP_CORS_ORIGIN=http://localhost:5173
APP_LOG_LEVEL=debug
APP_BASE_URL=http://localhost:3000
APP_ENV=development

# Auth
AUTH_BCRYPT_ROUNDS=10
AUTH_MAX_LOGIN_ATTEMPTS=10
AUTH_LOGIN_RATE_LIMIT_MS=1000
AUTH_PASSWORD_RESET_EXPIRY_MS=3600000

# ============================================================
# PostgreSQL Container
# ============================================================
POSTGRES_DB=placement_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev_password_only

# ============================================================
# MinIO Container
# ============================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================================
# MailHog
# ============================================================
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ============================================================
# App Ports
# ============================================================
APP_PORT=3000
DB_PORT=5432
